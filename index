<script>
// ========== ERROR HANDLING ==========
window.onerror = (m, s, l) => {
    const t = document.getElementById('sys-error-toast');
    if(t) {
        document.getElementById('sys-error-msg').textContent = `[Line ${l}] ${m}`;
        t.style.display = 'block';
    }
    return false;
};

// ========== DATA LAYER ==========
const getData = (k, d=[]) => JSON.parse(localStorage.getItem(k)) || d;
const setData = (k, v) => localStorage.setItem(k, JSON.stringify(v));

// ========== AI ENGINE (Claude) ==========
async function askClaude(prompt, systemMsg = "", btnId = "", isJson = false) {
    const apiKey = localStorage.getItem('claude_api_key');
    if (!apiKey) { alert("กรุณาตั้งค่า API Key ในหน้าตั้งค่า"); showPage('settings'); return null; }
    const btn = btnId ? document.getElementById(btnId) : null;
    const old = btn?.innerText;
    if(btn) { btn.innerText = "⏳ Claude is thinking..."; btn.disabled = true; }
    try {
        const response = await fetch('https://api.anthropic.com/v1/messages', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'x-api-key': apiKey, 'anthropic-version': '2023-06-01', 'dangerously-allow-browser': 'true' },
            body: JSON.stringify({ model: "claude-3-5-sonnet-20241022", max_tokens: 2048, system: systemMsg, messages: [{ role: "user", content: prompt }] })
        });
        const data = await response.json();
        if(!response.ok) throw new Error(data.error?.message || "Connection Error");
        let resText = data.content[0].text;
        if(isJson) {
            resText = resText.replace(/```json\n?/gi, '').replace(/```\n?/gi, '').trim();
            return JSON.parse(resText);
        }
        return resText;
    } catch (e) { alert("API Error: " + e.message); return null; }
    finally { if(btn) { btn.innerText = old; btn.disabled = false; } }
}

// ========== STATS SYSTEM ==========
let chartInstance = null;
function renderStats() {
    const wks = getData('my_workouts');
    const labels = []; const dists = [];
    for(let i=6; i>=0; i--) {
        const d = new Date(); d.setDate(d.getDate() - i);
        const ds = d.toISOString().slice(0,10);
        labels.push(d.toLocaleDateString('th-TH', {day:'numeric', month:'short'}));
        dists.push(wks.filter(w=>w.date===ds).reduce((s,w)=>s+parseFloat(w.dist||0),0));
    }
    const ctx = document.getElementById('chart-week-trend').getContext('2d');
    if(chartInstance) chartInstance.destroy();
    chartInstance = new Chart(ctx, { type: 'bar', data: { labels, datasets: [{ data: dists, backgroundColor: '#3b82f6', borderRadius: 8 }] }, options: { responsive:true, maintainAspectRatio:false, plugins:{legend:{display:false}}}});
    document.getElementById('stat-wk-dist').textContent = dists.reduce((a,b)=>a+b,0).toFixed(1) + ' กม.';
    document.getElementById('stat-wk-count').textContent = wks.filter(w => new Date(w.date) >= new Date(Date.now() - 7*86400000)).length + ' ครั้ง';
}

async function analyzeFitnessAI() {
    const wks = getData('my_workouts').slice(0, 10);
    const summary = wks.map(w => `${w.date}: ${w.dist}กม.`).join(', ');
    const out = document.getElementById('ai-fitness-output');
    out.style.display = 'block';
    out.innerText = "⏳ Claude กำลังวิเคราะห์...";
    const res = await askClaude(`ข้อมูลการซ้อม: ${summary}. ช่วยวิเคราะห์และแนะนำ 3 ข้อ`, "คุณคือโค้ชวิ่งวิทยาศาสตร์การกีฬา", "btn-analyze-fitness");
    if(res) out.innerText = res;
}

function switchStatsTab(tab, el) {
    document.querySelectorAll('#page-fitness-stats .tab').forEach(t=>t.classList.remove('active'));
    el.classList.add('active');
    document.getElementById('stats-week-view').style.display = tab==='week'?'block':'none';
    document.getElementById('stats-month-view').style.display = tab==='month'?'block':'none';
    if(tab==='month') renderMonthStats();
}

function renderMonthStats() {
    const wks = getData('my_workouts');
    const dataPoints = [0,0,0,0];
    wks.forEach(w => {
        const d = new Date(w.date);
        const weekIdx = Math.floor((d.getDate() - 1) / 7);
        if(weekIdx < 4) dataPoints[weekIdx] += parseFloat(w.dist || 0);
    });
    const ctx = document.getElementById('chart-month-trend').getContext('2d');
    new Chart(ctx, { type: 'line', data: { labels: ['W1', 'W2', 'W3', 'W4'], datasets: [{ label: 'กม.', data: dataPoints, borderColor: '#10b981', tension: 0.4, fill: true, backgroundColor: 'rgba(16, 185, 129, 0.1)' }] }, options: { responsive:true, maintainAspectRatio:false }});
}

// ========== DOC SYSTEM ==========
let currentDocType = 'out';
function updateDocPreview() {
    const esc = s => (s||'').replace(/[&<>'"]/g, t => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[t]));
    const v = id => esc(document.getElementById(id)?.value);
    const garudaBase64 = localStorage.getItem('garudaImg');
    const garudaHtml = garudaBase64 ? `<img src="${garudaBase64}" style="height:${currentDocType==='out'?'3cm':'1.5cm'}; width:auto;">` : `<div style="width:1.5cm; height:1.5cm; border:1px solid #000; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:bold;">ครุฑ</div>`;

    if (currentDocType === 'out') {
        document.getElementById('doc-render-area').innerHTML = `
            <div style="display:flex; justify-content:center; margin-bottom:5px;">${garudaHtml}</div>
            <div style="display:flex; justify-content:space-between; margin-bottom:10px;">
                <div style="display:flex;">ที่&nbsp;&nbsp;&nbsp;&nbsp;${v('do-num')}</div>
                <div style="width:40%; white-space:pre-wrap; line-height:1.2;">${v('do-dept')}</div>
            </div>
            <div style="margin-left:7.5cm; margin-bottom:10px;">${v('do-date')}</div>
            <div style="display:flex;"><div style="width:3cm; flex-shrink:0;">เรื่อง</div><div style="white-space:pre-wrap">${v('do-subject')}</div></div>
            <div style="display:flex;"><div style="width:3cm; flex-shrink:0;">เรียน</div><div style="white-space:pre-wrap">${v('do-to')}</div></div>
            <div style="display:flex; margin-bottom:10px;"><div style="width:3cm; flex-shrink:0;">สิ่งที่ส่งมาด้วย</div><div style="white-space:pre-wrap; flex:1;">${v('do-attach')}</div></div>
            <div style="margin-top:24pt; text-indent:2.5cm; white-space:pre-wrap;">${v('do-body')}</div>
            <div style="margin-top:16pt; text-indent:2.5cm; white-space:pre-wrap;">${v('do-conclusion')}</div>
            <div style="margin-top:48pt; margin-left:7.5cm; width:7.5cm; text-align:center;">
                <div style="text-align:left; padding-left:0.5cm; margin-bottom:48pt;">ขอแสดงความนับถือ</div>
                <div>(${v('do-signer')})</div><div>${v('do-pos')}</div>
            </div>
            <div style="margin-top:auto; line-height:1;">
                <div>${v('do-contact-name')}</div><div>${v('do-contact-phone')}</div>
                <div style="text-align:center; margin-top:20px; font-weight:bold; font-size:18pt; white-space:pre-wrap;">${v('do-slogan')}</div>
            </div>`;
    } else {
        document.getElementById('doc-render-area').innerHTML = `
            <div style="display:flex; align-items:flex-start; gap:20px; margin-bottom:10px;">
                ${garudaHtml} <div style="font-size:26pt; font-weight:bold; padding-top:10px;">บันทึกข้อความ</div>
            </div>
            <div style="display:flex;"><div style="width:3cm; font-weight:bold">ส่วนราชการ</div><div style="white-space:pre-wrap; flex:1;">${v('do-dept')}</div></div>
            <div style="display:flex; margin-bottom:5px;"><div style="width:50%; display:flex;"><div style="width:1cm; font-weight:bold">ที่</div><div>${v('do-num')}</div></div><div style="width:50%; display:flex;"><div style="width:1.5cm; font-weight:bold">วันที่</div><div>${v('do-date')}</div></div></div>
            <div style="display:flex;"><div style="width:3cm; font-weight:bold">เรื่อง</div><div style="white-space:pre-wrap; flex:1;">${v('do-subject')}</div></div>
            <div style="display:flex; margin-bottom:15px;"><div style="width:3cm; font-weight:bold">เรียน</div><div style="white-space:pre-wrap; flex:1;">${v('do-to')}</div></div>
            <div style="margin-top:16pt; text-indent:2.5cm; white-space:pre-wrap;">${v('do-body')}</div>
            <div style="margin-top:16pt; text-indent:2.5cm; white-space:pre-wrap;">${v('do-conclusion')}</div>
            <div style="margin-top:48pt; margin-left:7.5cm; width:7.5cm; text-align:center;">
                <div style="margin-top:32pt;">(${v('do-signer')})</div><div>${v('do-pos')}</div>
            </div>`;
    }
}

// ========== MAIN ACTIONS ==========
function renderToday() {
    const wks = getData('my_workouts');
    const totalDist = wks.filter(w => new Date(w.date) >= new Date(Date.now() - 7*86400000)).reduce((s,w)=>s+parseFloat(w.dist||0),0);
    document.getElementById('t-distance').textContent = totalDist.toFixed(1) + ' กม.';
    document.getElementById('t-docs').textContent = getData('my_docs').length;
    document.getElementById('today-recent-workouts').innerHTML = wks.slice(0,3).map(w=>`<div class="mb-12 text-sm">${w.date}: ${w.dist}กม.</div>`).join('') || '<p class="text2 text-sm">ไม่มีข้อมูล</p>';
}

function showPage(id) {
    document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
    document.getElementById('page-'+id)?.classList.add('active');
    const map = {today:0,'fitness-log':1,'fitness-stats':2,coach:3,'doc-summary':4,'doc-create':5,'doc-list':6,news:7,settings:8};
    document.querySelectorAll('.nav-item')[map[id]||0]?.classList.add('active');
    if(id==='today') renderToday();
    if(id==='fitness-stats') renderStats();
    if(id==='doc-create') updateDocPreview();
}

async function processImageWithAI(event) {
    const files = event.target.files; if (!files.length) return;
    const btn = document.getElementById('btn-sync-image');
    btn.innerText = "⏳ กำลังสกัด...";
    try {
        const res = await askClaude("Extract running data: {distance: number, time: number}", "You are a data extractor.", "btn-sync-image", true);
        if(res) { document.getElementById('r-distance').value = res.distance; document.getElementById('r-time').value = res.time; }
    } catch(e) { alert(e.message); } finally { btn.innerText = "📸 สกัดรูปภาพ (AI)"; }
}

async function summarizeDoc() {
    const txt = document.getElementById('ai-doc-input').value;
    const out = document.getElementById('ai-doc-output-page');
    const res = await askClaude(txt, "สรุปหนังสือราชการ 3 ข้อ", "btn-doc-ai");
    if(res) { out.innerText = res; out.style.display = 'block'; }
}

async function askNews() {
    const q = document.getElementById('news-query').value;
    const out = document.getElementById('news-output');
    out.style.display = 'block'; out.innerText = "⏳ กำลังค้นหา...";
    const res = await askClaude(q, "สรุปข่าว 3 ข้อ พร้อมวิเคราะห์เป็นภาษาไทย", "btn-news");
    if(res) out.innerText = res;
}

function saveWorkout() {
    const date = document.getElementById('f-date').value || new Date().toISOString().slice(0,10);
    const dist = document.getElementById('r-distance').value;
    const list = getData('my_workouts'); list.unshift({date, dist}); setData('my_workouts', list);
    alert('บันทึกสำเร็จ ✅'); renderToday();
}

function saveDocDb() {
    const docs = getData('my_docs');
    docs.unshift({ id: Date.now(), num: document.getElementById('do-num').value, sub: document.getElementById('do-subject').value, date: document.getElementById('do-date').value });
    setData('my_docs', docs); alert('บันทึกแล้ว ✅');
}

function printDoc() {
    const content = document.getElementById('doc-render-area').innerHTML;
    const win = window.open('', '_blank');
    win.document.write(`<html><head><style>@font-face{font-family:'TH Sarabun New';src:local('TH Sarabun New');}body{margin:0;}.print-area{width:210mm;min-height:297mm;padding:2.5cm 2cm 2cm 3cm;font-family:'TH Sarabun New',serif;font-size:16pt;color:#000;display:flex;flex-direction:column;}</style></head><body><div class="print-area">${content}</div><script>window.print();<\/script></body></html>`);
    win.document.close();
}

function saveSettings() { localStorage.setItem('claude_api_key', document.getElementById('set-claude-key').value); alert('บันทึกแล้ว ✅'); }
function loadGaruda(e) { const r = new FileReader(); r.onload = (ev) => { localStorage.setItem('garudaImg', ev.target.result); document.getElementById('garuda-preview-thumb').innerHTML=`<img src="${ev.target.result}" style="width:100%">`; updateDocPreview(); }; r.readAsDataURL(e.target.files[0]); }
function clearGaruda() { localStorage.removeItem('garudaImg'); document.getElementById('garuda-preview-thumb').innerHTML=''; updateDocPreview(); }
function switchDocTab(t, el) { currentDocType=t; document.querySelectorAll('#page-doc-create .tab').forEach(x=>x.classList.remove('active')); el.classList.add('active'); updateDocPreview(); }

// ========== INIT ==========
window.onload = () => {
    document.getElementById('today-date-label').textContent = new Date().toLocaleDateString('th-TH',{weekday:'long',year:'numeric',month:'long',day:'numeric'});
    const savedImg = localStorage.getItem('garudaImg');
    if(savedImg) document.getElementById('garuda-preview-thumb').innerHTML=`<img src="${savedImg}" style="width:100%">`;
    showPage('today');
};
</script>
</body>
