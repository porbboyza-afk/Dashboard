    <div class="nav-item" onclick="showPage('doc-summary')"><span class="icon">📑</span><span>AI สรุปหนังสือเข้า</span></div>
    <div class="nav-item" onclick="showPage('doc-create')"><span class="icon">📝</span><span>สร้างหนังสือออก</span></div>
    <div class="nav-item" onclick="showPage('doc-list')"><span class="icon">📁</span><span>ทะเบียนหนังสือ</span></div>
    
