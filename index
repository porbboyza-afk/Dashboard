    <div class="nav-item" onclick="showPage('fitness-stats')"><span class="icon">📊</span><span>สถิติ & วิเคราะห์</span></div>
    <div class="nav-item" onclick="showPage('coach')"><span class="icon">🤖</span><span>AI โค้ชวิ่ง</span></div>
    
