    <div class="nav-item" onclick="showPage('news')"><span class="icon">📰</span><span>AI ถาม-ตอบ ข่าวสาร</span></div>
    
    <div class="nav-section">ระบบ</div>
    <div class="nav-item" onclick="showPage('settings')"><span class="icon">⚙️</span><span>ตั้งค่าระบบ</span></div>
  </div>
</nav>

